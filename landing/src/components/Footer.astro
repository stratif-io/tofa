---
import TofaWink from './TofaWink.astro';
import { githubRepoUrl } from '../lib/github';

const year = new Date().getFullYear();

const links = [
  { href: githubRepoUrl,                                                  label: 'GitHub',      key: 'github'      },
  { href: 'https://docs.tofa.stratif.io/',                                label: 'Docs',        key: 'docs'        },
  { href: 'https://github.com/stratif-io/tofa/releases',                  label: 'Releases',    key: 'releases'    },
  { href: 'https://github.com/stratif-io/tofa/discussions',               label: 'Discussions', key: 'discussions' },
  { href: 'https://github.com/stratif-io/tofa/blob/main/CONTRIBUTING.md', label: 'Contribute',  key: 'contribute'  },
  { href: 'https://github.com/stratif-io/tofa/blob/main/LICENSE',         label: 'MIT License', key: 'license'     },
];
---
<footer class="border-t border-border mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <div class="flex items-end gap-3 mb-6">
      <TofaWink size={48} class="text-brand" />
      <span class="font-display font-bold tracking-tight text-5xl sm:text-6xl text-text leading-none">TOFA</span>
    </div>
    <p class="max-w-2xl text-text-muted text-base leading-relaxed">
      Offline TOTP &amp; 2FA in your terminal and macOS menu bar. Open-source, MIT. No telemetry. <span class="italic font-medium text-brand">Ever.</span>
    </p>

    <nav aria-label="Footer navigation" class="mt-10 flex flex-wrap gap-x-7 gap-y-3 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          data-umami-event={`link-footer-${l.key}`}
          class="text-text-muted hover:text-text transition-colors"
        >{l.label}</a>
      ))}
    </nav>

    <div class="mt-12 pt-6 border-t border-border flex flex-wrap items-baseline justify-between gap-3 font-mono text-xs text-text-subtle">
      <span>
        Built by <a href="https://stratif.io" class="text-text-muted hover:text-text transition-colors">Carlo Abi Chahine</a>
        <span aria-hidden="true" class="mx-1">·</span>
        <a href="https://stratif.io" class="text-text-muted hover:text-text transition-colors">Stratif</a>
      </span>
      <span>© {year}</span>
    </div>
  </div>
</footer>
