---
import HeroDemo from './HeroDemo.astro';
import { getStars, formatStars, githubRepoUrl } from '../lib/github';

const stars = await getStars();
const starsLabel = formatStars(stars);

// Build-time random seeds for the OTP rain — stable for the SSR'd page,
// then re-shuffled client-side every few seconds for variety.
function randomCode() {
  const n = Math.floor(Math.random() * 1_000_000).toString().padStart(6, '0');
  return `${n.slice(0, 3)} ${n.slice(3)}`;
}
const otps = Array.from({ length: 22 }, () => ({
  code:     randomCode(),
  top:      4 + Math.random() * 92,     // %
  left:     3 + Math.random() * 94,     // %
  delay:    Math.random() * 7,           // s
  duration: 5 + Math.random() * 5,       // s (slower, more ambient)
  size:     0.72 + Math.random() * 0.58, // rem (less size variance — calmer)
}));
---
<section class="relative overflow-hidden">
  <div aria-hidden="true" class="absolute -top-32 -right-32 w-[480px] h-[480px] rounded-full bg-brand/20 blur-3xl pointer-events-none"></div>

  <div class="otp-rain" aria-hidden="true">
    {otps.map((o) => (
      <span
        class="otp"
        style={`top:${o.top}%; left:${o.left}%; animation-delay:${o.delay}s; animation-duration:${o.duration}s; font-size:${o.size}rem;`}
      >{o.code}</span>
    ))}
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-16 sm:pt-24 pb-12 relative">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <a
          href={githubRepoUrl}
          data-umami-event="cta-hero-badge"
          class="inline-flex items-center gap-2 font-mono text-xs px-3 py-1.5 rounded-full bg-brand-bg text-brand border border-brand/25 mb-6 hover:border-brand/60 transition-colors"
        >
          ★ open source · MIT · no telemetry
        </a>
        <h1 class="font-display font-bold tracking-tight text-[clamp(2.25rem,5.5vw,4rem)] leading-[1.05] text-text">
          Stop grabbing your <span class="italic font-medium text-brand">phone</span> for codes.
        </h1>
        <p class="mt-5 max-w-xl text-text-muted text-base sm:text-lg leading-relaxed">
          The open-source <strong class="text-text font-semibold">TOTP authenticator</strong> for the terminal and macOS menu bar. One offline vault. No cloud, no account.
        </p>
        <div class="mt-7 flex flex-wrap items-center gap-3">
          <a href="#install" data-umami-event="cta-hero-install" class="inline-flex items-center justify-center gap-2 min-h-[44px] px-5 rounded-tofa-md bg-brand text-on-brand text-sm font-semibold hover:bg-brand-hover transition-colors">
            Install TOFA →
          </a>
          <a
            href={githubRepoUrl}
            data-umami-event="cta-hero-star"
            class="group inline-flex items-center justify-center gap-2 min-h-[44px] px-5 rounded-tofa-md bg-transparent text-text border border-border-strong text-sm font-medium hover:border-brand transition-colors"
          >
            <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.75.75 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
            </svg>
            Star on GitHub
            {starsLabel && (
              <span class="font-mono text-xs px-1.5 py-0.5 rounded bg-bg-elevated text-text-muted group-hover:text-text transition-colors">{starsLabel}</span>
            )}
          </a>
          <a href="#demos" data-umami-event="cta-hero-demos" class="inline-flex items-center justify-center gap-2 min-h-[44px] px-3 rounded-tofa-md bg-transparent text-text-muted text-sm font-medium hover:text-text transition-colors">
            See the demos →
          </a>
        </div>
      </div>
      <div>
        <HeroDemo />
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const rain = document.querySelector('.otp-rain');
    if (!rain) return;
    const els = rain.querySelectorAll('.otp');
    if (!els.length) return;

    const code = () => {
      const n = Math.floor(Math.random() * 1_000_000).toString().padStart(6, '0');
      return n.slice(0, 3) + ' ' + n.slice(3);
    };

    let timers = [];
    const start = () => {
      if (timers.length) return;
      els.forEach((el) => {
        el.style.animationPlayState = '';
        const interval = 3000 + Math.random() * 3500;
        timers.push(window.setInterval(() => { el.textContent = code(); }, interval));
      });
    };
    const stop = () => {
      timers.forEach((id) => window.clearInterval(id));
      timers = [];
      els.forEach((el) => { el.style.animationPlayState = 'paused'; });
    };

    if (!('IntersectionObserver' in window)) { start(); return; }
    const io = new IntersectionObserver((entries) => {
      for (const e of entries) { e.isIntersecting ? start() : stop(); }
    }, { rootMargin: '100px', threshold: 0 });
    io.observe(rain);
  })();
</script>
