---
// Canonical colors live in docs/design/assets/svg/tofa-wink-{light,dark,white}.svg.
// - default (theme-aware): purple body, dark-ink face. Body shade flips with theme.
// - on-brand: white body, light-purple face. For use on brand/purple backgrounds.
//
// Face is ALWAYS dark ink (#0a0a12) on theme-aware variants — never white. This
// is the design-system canon; the legacy `variant="light"` that used #ffffff for
// the face has been retired.
interface Props {
  size?: number;
  class?: string;
  variant?: 'auto' | 'on-brand';
}
const { size = 64, class: className = '', variant = 'auto' } = Astro.props;

const onBrand = variant === 'on-brand';
// On-brand: white body + light-purple face. Auto: theme-aware via CSS vars.
const bodyFill = onBrand ? '#ffffff' : 'var(--wink-body)';
const faceFill = onBrand ? '#b89eff' : 'var(--wink-face)';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 128 128"
  aria-hidden="true"
  data-tofa-wink
  class={className}
>
  <path
    d="M 64 14 C 78 14 92 18 102 22 C 104 23 106 25 106 28 V 60 C 106 86 90 104 66 114 C 65 114 63 114 62 114 C 38 104 22 86 22 60 V 28 C 22 25 24 23 26 22 C 36 18 50 14 64 14 Z"
    fill={bodyFill}
  />

  <!-- Left eye: always open (QR square) -->
  <g class="tofa-eye eye-l">
    <rect x="40" y="46" width="18" height="18" rx="3" fill={faceFill}/>
    <rect x="46" y="52" width="6"  height="6"  rx="1" fill={bodyFill}/>
  </g>

  <!-- Right eye: closed (wink curve) by default; during the easter-egg
       wink it opens to a QR square, then winks closed again. -->
  <g class="tofa-eye eye-r">
    <path class="closed" d="M 70 56 Q 79 50 88 56" stroke={faceFill} stroke-width="4" fill="none" stroke-linecap="round"/>
    <g class="open">
      <rect x="70" y="46" width="18" height="18" rx="3" fill={faceFill}/>
      <rect x="76" y="52" width="6"  height="6"  rx="1" fill={bodyFill}/>
    </g>
  </g>

  <path d="M 48 82 Q 64 94 80 82" stroke={faceFill} stroke-width="4" fill="none" stroke-linecap="round"/>
</svg>
