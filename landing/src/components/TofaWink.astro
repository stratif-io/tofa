---
interface Props {
  size?: number;
  class?: string;
  variant?: 'auto' | 'dark' | 'light';
}
const { size = 64, class: className = '', variant = 'auto' } = Astro.props;
const body = variant === 'dark' ? '#b89eff' : variant === 'light' ? '#7559b8' : 'currentColor';
const face = variant === 'dark' ? '#14131f' : variant === 'light' ? '#ffffff' : 'var(--bg)';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 128 128"
  aria-hidden="true"
  data-tofa-wink
  class={className}
>
  <path d="M 64 14 C 78 14 92 18 102 22 C 104 23 106 25 106 28 V 60 C 106 86 90 104 66 114 C 65 114 63 114 62 114 C 38 104 22 86 22 60 V 28 C 22 25 24 23 26 22 C 36 18 50 14 64 14 Z" fill={body}/>
  <g class="tofa-eye-left">
    <rect x="40" y="46" width="18" height="18" rx="3" fill={face}/>
    <rect x="46" y="52" width="6" height="6" rx="1" fill={body}/>
  </g>
  <path d="M 70 56 Q 79 50 88 56" stroke={face} stroke-width="4" fill="none" stroke-linecap="round"/>
  <path d="M 48 82 Q 64 94 80 82" stroke={face} stroke-width="4" fill="none" stroke-linecap="round"/>
</svg>
