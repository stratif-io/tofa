---
import TofaWink from './TofaWink.astro';
---
<header class="sticky top-0 z-50 backdrop-blur-md bg-bg/80 border-b border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 h-14 flex items-center gap-6">
    <a href="/" class="flex items-center gap-2 text-text hover:text-brand transition-colors">
      <TofaWink size={28} class="text-brand" />
      <span class="font-display font-bold tracking-tight text-lg">TOFA</span>
    </a>
    <nav class="hidden md:flex items-center gap-5 text-sm font-medium text-text-muted">
      <a href="#features" class="hover:text-text transition-colors">Features</a>
      <a href="#demos" class="hover:text-text transition-colors">Demos</a>
      <a href="#compare" class="hover:text-text transition-colors">Compare</a>
      <a href="#install" class="hover:text-text transition-colors">Install</a>
      <a href="https://docs.tofa.stratif.io/" class="hover:text-text transition-colors">Docs</a>
    </nav>
    <div class="ml-auto flex items-center gap-2">
      <a
        href="https://github.com/stratif-io/tofa"
        aria-label="TOFA on GitHub"
        class="inline-flex items-center gap-1.5 font-mono text-xs px-3 py-1.5 rounded-tofa-md border border-border bg-surface text-text-muted hover:text-text hover:border-border-strong transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path fill-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>
</header>
