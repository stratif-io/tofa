---
import '../styles/globals.css';
import { resolveSeo, SITE, type SeoProps } from '../lib/seo';

interface Props extends SeoProps {
  jsonLd?: object[];
}
const { jsonLd = [], ...seoProps } = Astro.props;
const seo = resolveSeo(seoProps);

// Umami analytics — self-hosted at analytics.stratif.io. Script and
// /api/send are publicly bypassed in papa-data-infra's Caddy block.
// The website id is baked in at build time; absent in dev/local builds.
const UMAMI_WEBSITE_ID = import.meta.env.PUBLIC_UMAMI_WEBSITE_ID;
const UMAMI_SRC = 'https://analytics.stratif.io/script.js';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark" />
  <title>{seo.title}</title>
  <meta name="description" content={seo.description} />
  <link rel="canonical" href={seo.canonical} />
  <meta name="theme-color" content="#0a0a12" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={seo.canonical} />
  <meta property="og:title" content={seo.title} />
  <meta property="og:description" content={seo.description} />
  <meta property="og:image" content={seo.ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:site_name" content={SITE.name} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={seo.title} />
  <meta name="twitter:description" content={seo.description} />
  <meta name="twitter:image" content={seo.ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Fraunces:wght@700&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  />



  <!-- JSON-LD blocks -->
  {jsonLd.map((block) => (
    <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
  ))}

  {UMAMI_WEBSITE_ID && (
    <script
      is:inline
      defer
      src={UMAMI_SRC}
      data-website-id={UMAMI_WEBSITE_ID}
      data-domains="tofa.stratif.io"
    />
  )}
</head>
<body class="bg-bg text-text font-sans antialiased">
  <a href="#main" class="sr-only focus:not-sr-only">Skip to content</a>
  <slot />

  <!-- Easter egg: double-click Sir Wink and he blinks. Skipped inside <a> so navigation isn't hijacked. -->
  <script is:inline>
    (() => {
      const wire = (el) => {
        if (el.closest('a')) return;
        el.addEventListener('dblclick', (e) => {
          e.preventDefault();
          el.classList.remove('winking');
          // force reflow so re-adding the class restarts the animation if double-clicked rapidly
          void el.getBoundingClientRect();
          el.classList.add('winking');
          window.setTimeout(() => el.classList.remove('winking'), 720);
        });
      };
      document.querySelectorAll('[data-tofa-wink]').forEach(wire);
    })();
  </script>
</body>
</html>
