{
  "productName": "Tofa",
  "version": "0.9.0",
  "identifier": "io.stratif.tofa",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": [
      "icons/tray_icon.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "../../packaging/dmg-background.png",
        "windowSize": {
          "width": 528,
          "height": 320
        },
        "appPosition": {
          "x": 144,
          "y": 136
        },
        "applicationFolderPosition": {
          "x": 384,
          "y": 136
        }
      }
    }
  }
}