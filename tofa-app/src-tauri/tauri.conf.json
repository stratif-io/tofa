{
  "productName": "Tofa",
  "version": "0.12.0",
  "identifier": "io.stratif.tofa",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "dmg",
      "app"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": [
      "icons/tray_icon.png"
    ],
    "macOS": {
      "infoPlist": "Info.plist",
      "dmg": {
        "background": "../../packaging/dmg-background.png",
        "windowSize": {
          "width": 528,
          "height": 320
        },
        "appPosition": {
          "x": 144,
          "y": 136
        },
        "applicationFolderPosition": {
          "x": 384,
          "y": 136
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/stratif-io/tofa/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyQjNBMTE3NDFCMDRBNkMKUldSc1NyQkJGNkd6a2dNZXRGYWIyZDdLOERLSU4zdElQM2NOZytURFVDaFpLdndJTE42Y3lNd3MK"
    }
  }
}
